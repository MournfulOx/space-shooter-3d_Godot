[sub_resource type="GDScript" id="GDScript_6m6wx"]
script/source = "extends Area3D

var speed : float
var direction : float
var can_move := true

func _ready() -> void:
	direction = randf_range(-1, 1)
	position.z = -50
	position.x = randf_range(-15,15)
	var random_scale = randf_range(2, 4)
	scale = Vector3(random_scale, random_scale, random_scale)
	speed = randf_range(5, 10)

func _physics_process(delta: float) -> void:
	if can_move:
		position.z += speed * delta
		position.x += direction * speed * delta
		rotate_x(delta * 1.5)
		rotate_z(delta * 1.5)


func destroy() -> void:
	if not can_move:
		return
	can_move = false
	$Mesh.material_overlay.set_shader_parameter(\"progress\", 1.0)
	await get_tree().create_timer(0.2).timeout
	queue_free()

func _on_area_entered(area: Area3D) -> void:
	$AudioStreamPlayer3D.play()
	destroy()


func _on_body_entered(_Player : CharacterBody3D) -> void:
	GlobalRecord.player_died.emit()
	


func _on_visible_on_screen_notifier_3d_screen_exited() -> void:
	queue_free()
"

